{
    "enable": {
        "type": "bool",
        "default": true,
        "description": "启用 Whisper 主动消息功能"
    },
    "llm_provider_id": {
        "type": "string",
        "default": "",
        "description": "主动消息生成使用的 LLM 提供商",
        "hint": "留空则使用当前对话的模型",
        "_special": "select_provider"
    },
    "silence_trigger_minutes": {
        "type": "int",
        "default": 5,
        "description": "用户沉默多久后触发主动消息检查（分钟）",
        "slider": {"min": 1, "max": 30, "step": 1}
    },
    "timeout_max": {
        "type": "int",
        "default": 30,
        "description": "主动检查的最大退避间隔（分钟）",
        "slider": {"min": 1, "max": 120, "step": 1}
    },
    "max_consecutive": {
        "type": "int",
        "default": 3,
        "description": "最大连续主动消息数",
        "slider": {"min": 1, "max": 10, "step": 1}
    },
    "quiet_hours_start": {
        "type": "string",
        "default": "23:00",
        "description": "安静时段开始时间 (HH:MM)"
    },
    "quiet_hours_end": {
        "type": "string",
        "default": "08:00",
        "description": "安静时段结束时间 (HH:MM)"
    },
    "quiet_hours_enabled": {
        "type": "bool",
        "default": true,
        "description": "启用安静时段"
    },
    "max_history_messages": {
        "type": "int",
        "default": 20,
        "description": "发给 LLM 的最大历史消息数"
    },
    "segment_enabled": {
        "type": "bool",
        "default": true,
        "description": "启用分段发送"
    },
    "segment_threshold": {
        "type": "int",
        "default": 50,
        "description": "分段阈值（短于此字数不分段）",
        "slider": {"min": 50, "max": 500, "step": 10}
    },
    "segment_mode": {
        "type": "string",
        "default": "regex",
        "options": ["regex", "words"],
        "labels": ["正则表达式", "分段词列表"]
    },
    "segment_regex": {
        "type": "string",
        "default": ".*?[。？！~…\\n]+|.+$",
        "description": "分段正则表达式"
    },
    "segment_words": {
        "type": "string",
        "default": "。！？～…\n",
        "description": "分段词列表（字符集）"
    },
    "segment_delay_ms": {
        "type": "int",
        "default": 1500,
        "description": "分段发送间隔（毫秒）"
    },
    "proactive_prompt": {
        "type": "text",
        "default": "你正在与一个朋友私聊。\n现在是 {{current_time}}，对方已经有一段时间没有回复了（你已主动发送了 {{unanswered_count}} 条消息未得到回复）。\n\n请判断你是否应该主动发送一条消息。考虑以下因素：\n1. 对话的上下文和氛围\n2. 上次对话的内容是否需要跟进\n3. 你已经发送了多少条未回复的消息（避免骚扰）\n4. 当前时间是否合适发消息\n\n请以 JSON 格式回复：\n{\"should_send\": true/false, \"content\": \"你要发送的消息内容\", \"reason\": \"你做出这个判断原因\"}\n\n规则：\n- 只输出 JSON，不要有任何其他文字。\n- 如果 should_send=false，content 必须是空字符串。\n- 如果 should_send=true，content 必须是非空字符串。",
        "description": "主动消息判断提示词模板"
    },
    "mcp_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 MCP (Model Context Protocol) 支持"
    },
    "mcp_services": {
        "type": "list",
        "default": [],
        "description": "MCP 服务列表"
    },
    "spotify_context_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 Spotify 上下文功能（获取当前播放状态）"
    },
    "spotify_suggest_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 Spotify 歌曲推荐功能"
    },
    "spotify_mcp_command": {
        "type": "string",
        "default": "node data/mcp_servers/spotify-mcp-server/build/index.js",
        "description": "Spotify MCP 服务器启动命令"
    }
}
